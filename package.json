{
  "name": "control-system-analyzer",
  "version": "3.1.0",
  "description": "Advanced Control System Response Analyzer - Educational Tool",
  "type": "module",
  "main": "script.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint js/**/*.js",
    "lint:fix": "eslint js/**/*.js --fix",
    "format": "prettier --write \"**/*.{js,css,html,md}\"",
    "docs": "jsdoc -c jsdoc.json",
    "deploy": "gh-pages -d dist"
  },
  "keywords": [
    "control-systems",
    "engineering",
    "education",
    "visualization",
    "bode-plot",
    "root-locus",
    "stability-analysis"
  ],
  "author": "Kushal Pitaliya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tigmanshupatelec/Control_system_analyzer.git"
  },
  "devDependencies": {
    "@vitest/ui": "^1.0.0",
    "eslint": "^8.55.0",
    "gh-pages": "^6.1.0",
    "jsdoc": "^4.0.2",
    "prettier": "^3.1.1",
    "vite": "^5.0.10",
    "vitest": "^1.0.4",
    "@vitest/coverage-v8": "^1.0.4"
  },
  "dependencies": {},
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
